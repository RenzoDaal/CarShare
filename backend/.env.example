# Required: generate a strong random value, e.g. `openssl rand -hex 32`
SECRET_KEY=

# Required: API key for OpenRouteService (https://openrouteservice.org)
ORS_API_KEY=

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Email settings (set EMAIL_ENABLED=true to send real emails)
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CarShare <no-reply@yourdomain.com>
APP_BASE_URL=http://localhost:5173
