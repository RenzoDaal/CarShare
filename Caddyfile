carshare.services {
    encode gzip

    # API calls: /api/... → backend (strip /api)
    handle_path /api/* {
        reverse_proxy carshare-backend:8000 {
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Static files: /static/... → backend (DO NOT strip /static)
    handle /static/* {
        reverse_proxy carshare-backend:8000 {
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Everything else → frontend
    reverse_proxy carshare-frontend:80 {
        header_up X-Forwarded-Proto {scheme}
    }
}
