carshare.services {
    encode gzip

    # All API calls: /api/... → backend (without /api prefix)
    handle_path /api/* {
        reverse_proxy carshare-backend:8000 {
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Everything else → frontend
    reverse_proxy carshare-frontend:80 {
        header_up X-Forwarded-Proto {scheme}
    }
}
